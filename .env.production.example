NODE_ENV=production

ENVIRONMENT_PORT=3001
VIEWER_PORT=3000
TRAINER_PORT=8000
HTTP_PORT=80

# Browser requests use Nginx same-origin routes in docker-compose.prod.yml.
NUXT_PUBLIC_ENVIRONMENT_BASE_URL=/api/environment
NUXT_PUBLIC_TRAINER_BASE_URL=/api/trainer

WAREHOUSE_GRID_WIDTH=4
WAREHOUSE_GRID_HEIGHT=4
WAREHOUSE_MAX_STEPS=10
WAREHOUSE_ROBOT_START=0,0
WAREHOUSE_BOX_START=1,1
WAREHOUSE_GOAL_POSITION=3,3
WAREHOUSE_WALLS=
WAREHOUSE_REWARD_STEP=-1
WAREHOUSE_REWARD_CLOSER=1
WAREHOUSE_REWARD_FARTHER=-2
WAREHOUSE_REWARD_REPEAT=-3
WAREHOUSE_REWARD_INVALID=-5
WAREHOUSE_REWARD_PICKUP=10
WAREHOUSE_REWARD_DELIVERY=50
WAREHOUSE_REWARD_WALL=-5

ENVIRONMENT_BASE_URL=http://environment:3001
TRAINER_REQUEST_TIMEOUT_SECONDS=5
TRAINER_MODE=random
RANDOM_AGENT_EPISODES=5
RANDOM_AGENT_SEED=42
PPO_TOTAL_TIMESTEPS=2000
PPO_LEARNING_RATE=0.0003
PPO_N_STEPS=64
PPO_BATCH_SIZE=32
PPO_GAMMA=0.99
PPO_MODEL_PATH=/app/models/warehouse_ppo.zip
PPO_EVAL_EPISODES=3
